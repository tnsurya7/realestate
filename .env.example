# Database Configuration (PostgreSQL - Neon DB)
DATABASE_URL=jdbc:postgresql://your-neon-host.neon.tech:5432/your-database
DATABASE_USERNAME=your-username
DATABASE_PASSWORD=your-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400000

# Email Configuration (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Application Configuration
APP_ADMIN_EMAIL=admin@yourcompany.com
APP_CONTACT_PHONE=1234567890
APP_CONTACT_EMAIL=contact@yourcompany.com
APP_COMPANY_NAME=Your Real Estate Company
APP_COMPANY_ADDRESS=123 Main Street, City, State 12345

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080
