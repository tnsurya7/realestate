# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to Git
# ============================================

# ============================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@host.neon.tech:5432/realestatecrm
DATABASE_USERNAME=user
DATABASE_PASSWORD=password

# Legacy format (also supported)
DB_URL=postgresql://user:password@host.neon.tech:5432/realestatecrm
DB_USERNAME=user
DB_PASSWORD=password

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# 1. Enable 2FA on Gmail
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy 16-character password below
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================
# JWT SECURITY
# ============================================
# Generate with: openssl rand -base64 32
# Must be minimum 32 characters
JWT_SECRET=your-super-secret-key-min-32-chars-generated-with-openssl

# ============================================
# ADMIN CREDENTIALS
# ============================================
# These are used to seed the admin user on first startup
ADMIN_EMAIL=admin@realestatecrm.com
ADMIN_PASSWORD=Admin@123

# ============================================
# CONTACT INFORMATION
# ============================================
CONTACT_PHONE=9360004968
CONTACT_EMAIL=suryakumar56394@gmail.com
COMPANY_NAME=RealEstate CRM
COMPANY_ADDRESS=Anna Nagar, Chennai – 600040

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://realestatecrm.vercel.app

# ============================================
# SERVER CONFIGURATION
# ============================================
# Render sets PORT automatically, but can override
PORT=8080

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vercel)
# ============================================
VITE_API_URL=https://realestatecrm-api.onrender.com/api
VITE_CONTACT_PHONE=9360004968
VITE_CONTACT_EMAIL=suryakumar56394@gmail.com
VITE_COMPANY_NAME=RealEstate CRM

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================
# 
# RENDER BACKEND:
# 1. Go to https://dashboard.render.com
# 2. Create Web Service
# 3. Set all DATABASE_*, MAIL_*, JWT_SECRET, ADMIN_*, CONTACT_*, CORS_* variables
# 4. Build: mvn clean package
# 5. Start: java -jar target/backend-0.0.1-SNAPSHOT.jar
#
# VERCEL FRONTEND:
# 1. Go to https://vercel.com/dashboard
# 2. Set VITE_* variables
# 3. Build: npm run build
# 4. Output: dist
#
# NEON DATABASE:
# 1. Go to https://console.neon.tech
# 2. Create project
# 3. Copy connection string to DATABASE_URL
#
# GMAIL APP PASSWORD:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select Mail and Windows Computer
# 3. Generate 16-character password
# 4. Copy to MAIL_PASSWORD
#
# JWT SECRET:
# Generate with: openssl rand -base64 32
#
# ============================================
